AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET

# Vite exposes only vars prefixed with VITE_ to the client (SPA uses these)
VITE_AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN
VITE_AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
# Optional: API identifier from Auth0 Dashboard → APIs. When set, access tokens are issued for this audience.
VITE_AUTH0_AUDIENCE=YOUR_AUTH0_API_AUDIENCE

# Monterosa SDK (optional; fallbacks in config.ts)
VITE_MONTEROSA_HOST=YOUR_MONTEROSA_STATIC_HOST
VITE_MONTEROSA_PROJECT_ID=YOUR_MONTEROSA_PROJECT_ID
